# Emmett PostgreSQL event store (matches docker-compose.yml)
EVENTSTORE_CONNECTION_STRING=postgresql://foos:foos@localhost:5432/foos

# HTTP / WebSocket port
PORT=3000

# Career-stats ranking (best/worst teammate, nemeses). Optional — defaults shown.
# Minimum games a pairing must have (together / against) to be ranked at all.
CAREER_STATS_MIN_MATCHES=5
# Laplace smoothing strength added to wins and losses before the ratio is taken
# (tempers small samples). 0 = raw ratio.
CAREER_STATS_SMOOTHING=1
