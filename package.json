{
  "name": "foos",
  "version": "1.0.0",
  "private": true,
  "description": "Foosball league app — NestJS (Emmett event sourcing) backend + React SPA in one runtime",
  "scripts": {
    "build:web": "vite build",
    "build:server": "nest build",
    "build": "pnpm run build:web && pnpm run build:server",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "dev:web": "vite",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:migrated": "playwright test --config playwright.migrated.config.ts"
  },
  "dependencies": {
    "@event-driven-io/emmett": "^0.42.3",
    "@event-driven-io/emmett-postgresql": "^0.42.3",
    "@event-driven-io/pongo": "0.16.11",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/websockets": "^11.0.1",
    "chart.js": "^3.9.1",
    "chartjs-adapter-moment": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "elo-rating": "^1.0.1",
    "jsonwebtoken": "9",
    "moment": "^2.29.4",
    "passport": "^0.7.0",
    "passport-slack-oauth2": "^1.2.0",
    "react": "17.0.2",
    "react-bootstrap": "^2.1.2",
    "react-chartjs-2": "^4.3.1",
    "react-dom": "17.0.2",
    "react-gravatar": "^2.6.3",
    "react-helmet": "6.1.0",
    "react-redux": "7.2.6",
    "react-router": "^6.2.1",
    "react-router-dom": "^6.2.1",
    "redux": "^4.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.5",
    "socket.io": "^4.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.61.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.21"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
